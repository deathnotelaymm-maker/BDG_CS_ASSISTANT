NODE_ENV=production
APP_NAME=BDG Help Center
PORT=10000

# Neon pooled connection string; hostname must contain -pooler.
DATABASE_URL=postgresql://USER:PASSWORD@ENDPOINT-pooler.ap-southeast-1.aws.neon.tech/DATABASE?sslmode=require
# Neon direct connection string for Render pre-deploy migrations only.
MIGRATION_DATABASE_URL=postgresql://USER:PASSWORD@ENDPOINT.ap-southeast-1.aws.neon.tech/DATABASE?sslmode=require
DATABASE_PROVIDER=neon
DATABASE_SSL=true
REQUIRE_NEON_POOLER=true
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_CONNECT_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=20000
DB_IDLE_TIMEOUT_MS=30000
DB_KEEPALIVE_INITIAL_DELAY_MS=10000

ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=REPLACE_WITH_AT_LEAST_12_CHARACTERS
JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
RESET_OWNER_PASSWORD_ON_DEPLOY=false
ALLOWED_ORIGINS=https://bdg-guide-pages.pages.dev,https://bdg-chat-pages.pages.dev,https://bdg-admin-pages.pages.dev

DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_MODE_ENABLED=true

R2_REQUIRED=true
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bdg-ai-guide-images
R2_PUBLIC_BASE_URL=
